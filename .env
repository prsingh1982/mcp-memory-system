# Core paths
MEMORY_SQLITE_PATH=./data/sqlite/memory.db
MEMORY_FAISS_DIR=./data/faiss

# Local Ollama
OLLAMA_MODEL=gemma4:31b-cloud
#llama3.1:latest
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=5m
OLLAMA_API_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKL9pAFAduQXXdqHoGwjlnNMyfr0j2v8f2lRI5ZMlJAw

# Local embeddings
MEMORY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEMORY_EMBEDDING_DEVICE=
MEMORY_EMBEDDING_BATCH_SIZE=32

# Chunking
MEMORY_CHUNK_MAX_CHARS=1200
MEMORY_CHUNK_OVERLAP_CHARS=200
MEMORY_CHUNK_MIN_CHARS=250

# Optional Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mcp-memory-123
NEO4J_DATABASE=neo4j-mcp-memory-new

# MCP transport
MCP_TRANSPORT=stdio
